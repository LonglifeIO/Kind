        },
        "priority": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Priority"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "title": "Schema Version",
          "type": "string"
        },
        "segment_end": {
          "title": "Segment End",
          "type": "integer"
        },
        "segment_id": {
          "title": "Segment Id",
          "type": "integer"
        },
        "segment_start": {
          "title": "Segment Start",
          "type": "integer"
        },
        "t_event": {
          "title": "T Event",
          "type": "integer"
        },
        "total_segments": {
          "title": "Total Segments",
          "type": "integer"
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "checkpoint_id",
        "event_type",
        "t_event",
        "segment_id",
        "segment_start",
