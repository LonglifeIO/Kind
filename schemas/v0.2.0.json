        "priority",
        "buffer_size",
        "total_segments"
      ],
      "title": "ReplayMeta",
      "type": "object"
    },
    "WorldEvent": {
      "additionalProperties": false,
      "description": "One record per external event in the world.\n\nThe ``payload`` field is intentionally schemaless within itself (plan §3.4):\nthe same model carries per-event records (Probe 4's individual builder\nmutators) and per-episode aggregates (Probe 1's\n``internal_stochasticity_aggregate`` rollups). Adding new payload shapes\nfor future probes does not bump the schema version.",
      "properties": {
        "checkpoint_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Checkpoint Id"
        },
        "event_type": {
          "enum": [
            "builder_perturbation",
            "env_reset",
            "internal_stochasticity_aggregate",
            "mirror_marker"
          ],
          "title": "Event Type",
          "type": "string"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        },
        "run_id": {
          "title": "Run Id",
          "type": "string"
        },
        "schema_version": {
          "title": "Schema Version",
          "type": "string"
        },
        "source": {
          "enum": [
            "builder",
            "environment",
            "system"
          ],
          "title": "Source",
          "type": "string"
        },
        "t_event": {
          "title": "T Event",
          "type": "integer"
        },
        "wallclock_ms": {
          "title": "Wallclock Ms",
          "type": "integer"
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "checkpoint_id",
        "t_event",
        "event_type",
        "source",
        "payload",
        "wallclock_ms"
      ],
      "title": "WorldEvent",
      "type": "object"
    }
  },
  "schema_version": "0.2.0",
  "title": "Kind Telemetry Schemas"
}
